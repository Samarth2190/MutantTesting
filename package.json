{
  "name": "devopsproject-mutation-testing-framework",
  "version": "1.0.0",
  "description": "DevOps project implementing a mutation testing framework for Node.js applications using Stryker.",
  "main": "src/main/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/main/start.js",
    "start:cli": "node src/main/app.js",
    "test": "npm run test:unit",
    "test:unit": "mocha \"tests/unit/**/*.test.js\"",
    "test:mutation": "stryker run",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "ci": "npm run lint && npm run test && npm run test:mutation"
  },
  "keywords": [
    "devops",
    "mutation-testing",
    "stryker",
    "nodejs",
    "ci-cd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/mocha-runner": "^9.6.0",
    "chai": "^4.4.1",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "mocha": "^10.7.0",
    "supertest": "^6.3.4"
  }
}
