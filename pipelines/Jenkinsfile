pipeline {
  agent any

  environment {
    APP_NAME = 'devopsproject-mutation-testing-framework'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Dependencies') {
      steps {
        sh 'npm install'
      }
    }

    stage('Lint') {
      steps {
        sh 'npm run lint'
      }
    }

    stage('Unit Tests') {
      steps {
        sh 'npm test'
      }
    }

    stage('Mutation Testing') {
      steps {
        sh 'npm run test:mutation'
      }
    }

    stage('Build Docker Image') {
      steps {
        sh "docker build -t ${APP_NAME}:latest -f infrastructure/docker/Dockerfile ."
      }
    }
  }

  post {
    success {
      echo 'Pipeline completed successfully.'
    }
    failure {
      echo 'Pipeline failed. Please check the logs.'
    }
  }
}

